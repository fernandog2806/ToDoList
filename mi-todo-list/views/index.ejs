<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Mi Agenda Dinámica</title>
</head>

<body>
    <main class="app-container">
        <header>
            <h1>Mis tareas</h1>
        </header>

        <!-- SECCIÓN DE ENTRADA -->
        <section id="input-area">
            <label for="taskDate">Agendar para el día:</label>
            <input type="date" id="taskDate">

            <label for="taskTime">Agendar para la hora: (opcional)</label>
            <input type="time" id="taskTime">

            <div class="input-group">
                <input type="text" id="taskInput" placeholder="¿Qué quieres hacer?">
                <button id="addBtn">Añadir</button>
            </div>
        </section>


        <hr>

        <!-- SECCIÓN DE FILTRO CON CARRUSEL -->
        <section id="filter-area">
            <label>🔍 Ver tareas del día:</label>
            <div class="carousel-wrapper">
                <button class="nav-btn" onclick="scrollCarousel(-1)">❮</button>
                <div id="calendar-carousel" class="calendar-carousel">
                    <!-- Los días se generan con JS -->
                </div>
                <button class="nav-btn" onclick="scrollCarousel(1)">❯</button>
            </div>
        </section>

        <!-- SECCIÓN DE LISTA -->
        <section id="task-area">
            <div id="select-all-container" class="hidden">
                <input type="checkbox" id="selectAll">
                <label for="selectAll">Seleccionar todos</label>
            </div>

            <div id="taskList"></div>

            <button id="deleteBtn" class="hidden">Borrar seleccionadas</button>
        </section>
    </main>
    <script src="/js/main.js"></script>
</body>

</html>