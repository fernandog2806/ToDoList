<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Mi Agenda Dinámica</title>
</head>

<body>
    <main class="app-container">
        <header>
            <h1>Mis tareas</h1>
        </header>

        <!-- SECCIÓN DE ENTRADA -->
        <section id="input-area">
            <label for="taskDate">Agendar para el día:</label>
            <input type="date" id="taskDate">

            <label for="taskTime">Agendar para la hora: (opcional)</label>
            <input type="time" id="taskTime">

            <label for="taskPriority">Seleccione importancia:</label>
            <select id="taskPriority">
                <option value="p0">🔴 P0 — Crítico</option>
                <option value="p1">🟠 P1 — Alto</option>
                <option value="p2">🟡 P2 — Medio</option>
                <option value="p3">🟢 P3 — Bajo</option>
            </select>

            <div class="input-group">
                <input type="text" id="taskInput" placeholder="¿Qué quieres hacer?">
                <button id="addBtn">Añadir</button>
            </div>
        </section>

        <hr>

        <!-- SECCIÓN DE FILTRO CON CARRUSEL -->
<section id="priority-selector-area">
    <p class="selector-title">Seleccione prioridad del:</p>
    <div class="priority-radio-group">

        <!-- P0 CRÍTICO -->
        <label class="radio-card">
            <input type="radio" name="priority" value="p0" checked>
            <span class="pill-dot red-pill">
                P0
                <span class="tooltip-text">
                    <strong>🔴 Crítico / Emergencia</strong><br>
                    • Impacto: máximo<br>• Urgencia: inmediata<br>
                    • Ejemplo: sistema caído, riesgo legal o financiero<br>
                    <em>👉 "Todo está roto o no se puede operar"</em>
                </span>
            </span>
        </label>

        <!-- P1 ALTO -->
        <label class="radio-card">
            <input type="radio" name="priority" value="p1">
            <span class="pill-dot orange-pill">
                P1
                <span class="tooltip-text">
                    <strong>🟠 Alto</strong><br>
                    • Impacto: alto<br>• Urgencia: muy alta<br>
                    • Ejemplo: funcionalidad clave no funciona<br>
                    <em>👉 "Funciona mal algo importante"</em>
                </span>
            </span>
        </label>

        <!-- P2 MEDIO -->
        <label class="radio-card">
            <input type="radio" name="priority" value="p2">
            <span class="pill-dot yellow-pill">
                P2
                <span class="tooltip-text">
                    <strong>🟡 Medio</strong><br>
                    • Impacto: moderado<br>• Urgencia: media<br>
                    • Ejemplo: bug con workaround (solución temporal)<br>
                    <em>👉 "Molesta, pero se puede seguir"</em>
                </span>
            </span>
        </label>

        <!-- P3 BAJO -->
        <label class="radio-card">
            <input type="radio" name="priority" value="p3">
            <span class="pill-dot green-pill">
                P3
                <span class="tooltip-text">
                    <strong>🟢 Bajo</strong><br>
                    • Impacto: bajo<br>• Urgencia: baja<br>
                    • Ejemplo: mejoras o temas estéticos<br>
                    <em>👉 "Backlog / Cuando haya capacidad"</em>
                </span>
            </span>
        </label>

    </div>
</section>

        <section id="filter-area">
            <label>🔍 Ver tareas del día:</label>
            <div class="carousel-wrapper">
                <button class="nav-btn" onclick="scrollCarousel(-1)">❮</button>
                <div id="calendar-carousel" class="calendar-carousel">
                    <!-- Los días se generan con JS -->
                </div>
                <button class="nav-btn" onclick="scrollCarousel(1)">❯</button>
            </div>
        </section>

        <!-- SECCIÓN DE LISTA MEJORADA -->
        <section id="task-area">
        <div id="select-all-container">
            <div class="toolbar-row-top">
                <div class="tool-group">
                    <input type="checkbox" id="selectAll">
                    <label for="selectAll">Selec. todos</label>
                </div>
                <button id="deleteBtn" class="hidden">Borrar seleccionadas</button>
            </div>
        
            <div class="toolbar-row-bottom">
                <!-- ENVOLTORIO PARA QUE FECHA Y HORA SE APILEN JUNTOS -->
                <div class="inputs-wrapper">
                    <div class="tool-group">
                        <label for="moveTaskDate">📅 Cambiar día:</label>
                        <input type="date" id="moveTaskDate">
                    </div>
                    <div class="tool-group">
                        <label for="moveTaskTime">⏰ Cambiar hora:</label>
                        <input type="time" id="moveTaskTime">
                    </div>
                </div>
        
                <!-- EL BOTÓN QUEDA FUERA PARA ESTAR A LA DERECHA -->
                <button id="applyChangesBtn" disabled>Mover</button>
            </div>
        </div>


        <div id="taskListHeader" class="task-list-header">
            <span for="taskListTitle">Selec</span>
            <span for="taskListTitle">Mensaje / Tarea</span>
            <span for="taskListTitle">Hecha</span>
            <span for="taskListTitle">Editar</span>
        </div>


            <div id="taskList"></div>
        </section>
    </main>

    <script src="/js/main.js"></script>
</body>

</html>